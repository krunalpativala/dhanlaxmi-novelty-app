rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && (
          request.auth.token.email in ['krunalpativala@gmail.com']
          || (
            firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
            && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
          )
        );
    }

    function isValidImageUpload() {
      return request.resource != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Admin product and category images
    match /product_images/{fileName} {
      allow read: if signedIn();
      allow write: if isAdmin() && isValidImageUpload();
      allow delete: if isAdmin();
    }

    match /category_images/{fileName} {
      allow read: if signedIn();
      allow write: if isAdmin() && isValidImageUpload();
      allow delete: if isAdmin();
    }

    // User-owned uploads, if Firebase Storage is used later.
    match /user_uploads/{userId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if request.auth.uid == userId && isValidImageUpload();
      allow delete: if request.auth.uid == userId || isAdmin();
    }

    match /{allPaths=**} {
      allow read: if signedIn();
      allow write, delete: if false;
    }
  }
}
