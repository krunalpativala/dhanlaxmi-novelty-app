rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && (
          request.auth.token.email in ['krunalpativala@gmail.com']
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
          )
        );
    }

    function hasValidOrderTotals() {
      return request.resource.data.totalProducts is int
        && request.resource.data.totalQuantity is int
        && request.resource.data.totalAmount is number
        && request.resource.data.items is list
        && request.resource.data.createdAt == request.time;
    }

    function isValidRetailerOrder() {
      return request.resource.data.keys().hasOnly([
          'retailerUid',
          'retailerName',
          'shopName',
          'phone',
          'note',
          'status',
          'totalProducts',
          'totalQuantity',
          'totalAmount',
          'items',
          'createdAt'
        ])
        && request.resource.data.retailerUid == request.auth.uid
        && request.resource.data.status == 'new'
        && request.resource.data.retailerName is string
        && request.resource.data.shopName is string
        && request.resource.data.phone is string
        && request.resource.data.note is string
        && hasValidOrderTotals();
    }

    function isValidCustomerOrder() {
      return request.resource.data.keys().hasOnly([
          'customerUid',
          'customerName',
          'deliveryAddress',
          'phone',
          'paymentMethod',
          'status',
          'totalProducts',
          'totalQuantity',
          'totalAmount',
          'items',
          'createdAt'
        ])
        && request.resource.data.customerUid == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.customerName is string
        && request.resource.data.deliveryAddress is string
        && request.resource.data.phone is string
        && request.resource.data.paymentMethod in ['cod', 'online']
        && hasValidOrderTotals();
    }

    match /users/{userId} {
      allow create: if isOwner(userId)
        && request.resource.data.role == 'pending';
      allow read: if isOwner(userId) || isAdmin();
      allow update: if isAdmin()
        || (isOwner(userId)
          && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    match /carts/{userId} {
      allow read, write, delete: if isOwner(userId);
    }

    match /products/{productId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if signedIn()
        && (isValidRetailerOrder() || isValidCustomerOrder());

      allow read: if isAdmin()
        || (signedIn() && resource.data.retailerUid == request.auth.uid)
        || (signedIn() && resource.data.customerUid == request.auth.uid);

      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['status', 'statusUpdatedAt', 'statusUpdatedBy'])
        && request.resource.data.status in [
          'new',
          'pending',
          'confirmed',
          'packed',
          'delivered'
        ];

      allow delete: if isAdmin();
    }
  }
}
